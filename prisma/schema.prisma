generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  SUPERADMIN
}

enum UserAccountStatus {
  ACTIVE
  SUSPENDED
}

model User {
  id            String    @id @default(uuid())
  uid           String    @unique
  email         String
  normalizedEmail String  @unique
  username      String
  passwordHash  String
  friendCode    String    @unique
  role          UserRole  @default(USER)
  accountStatus UserAccountStatus @default(ACTIVE)
  suspendedAt   DateTime?
  deletionRequestedAt DateTime?
  deletionNextAttemptAt DateTime?
  deletionAttemptCount Int @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile          Profile?
  friendships      Friendship[]  @relation("UserFriendships")
  friendsOf        Friendship[]  @relation("FriendOf")
  sentRequests     FriendRequest[] @relation("SentRequests")
  receivedRequests FriendRequest[] @relation("ReceivedRequests")
  sentVisits       Visit[]       @relation("SentVisits")
  receivedVisits   Visit[]       @relation("ReceivedVisits")
  notifications    Notification[]
  presence         Presence?
  deviceSessions   DeviceSession[]
  blockedUsers     BlockedUser[] @relation("Blocker")
  blockedBy        BlockedUser[] @relation("Blocked")
  discoveries      Discovery[]
  networkCompanions NetworkCompanion[] @relation("OwnedNetworkCompanions")
  activeNetworkCompanionId String? @unique
  activeNetworkCompanion NetworkCompanion? @relation("UserActiveNetworkCompanion", fields: [activeNetworkCompanionId], references: [id])
  visitInvitationsOwned VisitInvitation[] @relation("VisitInvitationVisitorOwner")
  visitInvitationsHosted VisitInvitation[] @relation("VisitInvitationHost")
  visitSessionsOwned VisitSession[] @relation("VisitSessionVisitorOwner")
  visitSessionsHosted VisitSession[] @relation("VisitSessionHost")
  debugEvents       DeveloperDebugEvent[]

  @@index([username])
  @@index([role])
  @@index([accountStatus])
  @@index([deletionRequestedAt])
  @@index([deletionNextAttemptAt, id])
}

model DeviceSession {
  id                      String    @id @default(uuid())
  userId                  String
  deviceId                String
  refreshTokenHash        String
  previousRefreshTokenHash String?
  csrfTokenHash           String?
  createdAt               DateTime  @default(now())
  lastUsedAt              DateTime  @updatedAt
  expiresAt               DateTime
  revokedAt               DateTime?
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([deviceId])
}

model Profile {
  id          String  @id @default(uuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String?
  avatarUrl   String?
  bio         String?
  isPublic    Boolean @default(false)
}

model FriendRequest {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@index([senderId, status])
}

model Friendship {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friendId  String
  friend    User     @relation("FriendOf", fields: [friendId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, friendId])
}

model Visit {
  id          String    @id @default(uuid())
  senderId    String
  sender      User      @relation("SentVisits", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User      @relation("ReceivedVisits", fields: [receiverId], references: [id], onDelete: Cascade)
  content     Json
  status      String    @default("pending")
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Presence {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status     String   @default("offline")
  lastSeenAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model BlockedUser {
  id         String   @id @default(uuid())
  blockerId  String
  blocker    User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId  String
  blocked    User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([blockerId, blockedId])
}

model Discovery {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  metadata    Json
  createdAt   DateTime @default(now())
}

model NetworkCompanion {
  id                String   @id @default(uuid())
  ownerUserId       String
  owner             User     @relation("OwnedNetworkCompanions", fields: [ownerUserId], references: [id], onDelete: Cascade)
  name              String
  publicDescription String?
  publicTags        String[] @default([])
  visibility        String   @default("friends_only")
  published         Boolean  @default(false)
  activeAssetPackId String?  @unique
  activeAssetPack   CompanionAssetPack? @relation("ActiveAssetPack", fields: [activeAssetPackId], references: [id])
  activeForUser     User?    @relation("UserActiveNetworkCompanion")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  publishedAt       DateTime?
  assetPacks        CompanionAssetPack[] @relation("CompanionAssetPacks")
  visitInvitations  VisitInvitation[]
  visitSessions     VisitSession[]

  @@index([ownerUserId])
}

model CompanionAssetPack {
  id               String   @id @default(uuid())
  companionId      String
  companion        NetworkCompanion @relation("CompanionAssetPacks", fields: [companionId], references: [id], onDelete: Cascade)
  manifestHash     String
  schemaVersion    Int
  manifest         Json
  status           String
  objectPrefix     String
  totalFiles       Int
  totalBytes       BigInt
  failureCode      String?
  lastUploadUrlIssuedAt DateTime?
  stagingCleanedAt DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  completedAt      DateTime?
  activatedAt      DateTime?
  supersededAt     DateTime?
  files            CompanionAssetFile[]
  activeForCompanion NetworkCompanion? @relation("ActiveAssetPack")
  visitInvitationRefs VisitInvitation[] @relation("VisitInvitationAssetPackRef")
  visitSessionRefs    VisitSession[] @relation("VisitSessionAssetPackRef")

  @@unique([companionId, manifestHash])
  @@index([companionId, status])
  @@index([status, stagingCleanedAt])
}

model CompanionAssetFile {
  id           String   @id @default(uuid())
  assetPackId  String
  assetPack    CompanionAssetPack @relation(fields: [assetPackId], references: [id], onDelete: Cascade)
  relativePath String
  objectKey    String   @unique
  mimeType     String
  sizeBytes    BigInt
  sha256       String
  category     String
  uploaded     Boolean  @default(false)
  verifiedAt   DateTime?

  @@unique([assetPackId, relativePath])
}

model VisitInvitation {
  id                   String   @id @default(uuid())
  visitorOwnerUserId   String
  visitorOwner         User     @relation("VisitInvitationVisitorOwner", fields: [visitorOwnerUserId], references: [id], onDelete: Cascade)
  hostUserId           String
  host                 User     @relation("VisitInvitationHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  networkCompanionId   String
  networkCompanion     NetworkCompanion @relation(fields: [networkCompanionId], references: [id], onDelete: Restrict)
  assetPackSnapshotId  String
  assetPackRefId       String?
  assetPackRef         CompanionAssetPack? @relation("VisitInvitationAssetPackRef", fields: [assetPackRefId], references: [id], onDelete: SetNull)
  companionName        String
  companionDescription String?
  companionTags        String[] @default([])
  status               String
  expiresAt            DateTime
  respondedAt          DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  session              VisitSession?

  @@index([visitorOwnerUserId, status])
  @@index([hostUserId, status])
  @@index([expiresAt, status])
  @@index([assetPackRefId, status])
}

model VisitSession {
  id                   String   @id @default(uuid())
  invitationId         String   @unique
  invitation           VisitInvitation @relation(fields: [invitationId], references: [id], onDelete: Restrict)
  visitorOwnerUserId   String
  visitorOwner         User     @relation("VisitSessionVisitorOwner", fields: [visitorOwnerUserId], references: [id], onDelete: Cascade)
  hostUserId           String
  host                 User     @relation("VisitSessionHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  networkCompanionId   String
  networkCompanion     NetworkCompanion @relation(fields: [networkCompanionId], references: [id], onDelete: Restrict)
  assetPackSnapshotId  String
  assetPackRefId       String?
  assetPackRef         CompanionAssetPack? @relation("VisitSessionAssetPackRef", fields: [assetPackRefId], references: [id], onDelete: SetNull)
  state                String
  visitorOwnerReadyAt  DateTime?
  hostReadyAt          DateTime?
  visitorOwnerSeenAt   DateTime?
  hostSeenAt           DateTime?
  readyAt              DateTime?
  startedAt            DateTime?
  endingAt             DateTime?
  endedAt              DateTime?
  endReason            String?
  failureCode          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([visitorOwnerUserId, state])
  @@index([hostUserId, state])
  @@index([assetPackRefId, state])
  @@index([updatedAt, state])
}

model AdminAuditLog {
  id            String   @id @default(uuid())
  adminUserId   String
  action        String
  targetType    String
  targetId      String?
  reason        String?
  metadata      Json?
  ipAddressHash String?
  createdAt     DateTime @default(now())

  @@index([adminUserId, createdAt])
  @@index([targetType, targetId])
  @@index([createdAt, id])
}

model DeveloperDebugEvent {
  id              String   @id @default(uuid())
  clientEventId   String
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId        String
  kind            String
  operation       String?
  status          String?
  provider        String?
  model           String?
  companionId     String?
  correlationId   String?
  cycleId         String?
  turnId          String?
  summary         String?
  payload         Json
  errorCode       String?
  clientCreatedAt DateTime
  receivedAt      DateTime @default(now())
  expiresAt       DateTime

  @@unique([userId, clientEventId])
  @@index([userId, receivedAt])
  @@index([kind, receivedAt])
  @@index([correlationId])
  @@index([cycleId])
  @@index([expiresAt])
}
