# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/our_companion_network?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRATION="15m"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
JWT_REFRESH_EXPIRATION="7d"

# Server
PORT=3001
CORS_ORIGIN="http://localhost:3000"
# Default: 45 seconds. Set to 0 only to explicitly disable reconnect grace.
PRESENCE_DISCONNECT_GRACE_SECONDS=45
PROTOCOL_VERSION=0.3
MINIMUM_CLIENT_VERSION=0.3.0
SERVER_VERSION=0.3.0
VISIT_INVITATION_TTL_HOURS=24
VISIT_PREPARATION_TTL_MINUTES=10
VISIT_SESSION_MAX_MINUTES=30
VISIT_HEARTBEAT_INTERVAL_SECONDS=15
VISIT_HEARTBEAT_TIMEOUT_SECONDS=60

# Redis (for rate limiting)
REDIS_URL="redis://localhost:6379"
CLOUDFLARE_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_REGION=auto
R2_MAX_ASSET_FILE_BYTES=20971520
R2_MAX_ASSET_PACK_BYTES=524288000
R2_MAX_ASSET_PACK_FILES=1000
R2_UPLOAD_URL_TTL_SECONDS=900
R2_DOWNLOAD_URL_TTL_SECONDS=900
R2_UPLOAD_SESSION_TTL_HOURS=24
R2_SUPERSEDED_PACK_RETENTION_DAYS=30
R2_MAX_USER_STORAGE_BYTES=2147483648
